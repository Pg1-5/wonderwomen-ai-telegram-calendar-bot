          "value": "your-calendar-id@gmail.com",
          "mode": "id",
          "__regex": "(^[a-zA-Z0-9.!#$%&’*+/=?^_`{|}~-]+@[a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*)"
        },
        "start": "={{\n(() => {\n  const raw = $node[\"Message a model\"].json.output[0].content[0].text;\n  const data = JSON.parse(raw);\n\n  return `${data.date}T${data.time}:00`;\n})()\n}}",
        "end": "={{\n(() => {\n  const raw = $node[\"Message a model\"].json.output[0].content[0].text;\n  const data = JSON.parse(raw);\n\n  const [hour, minute] = data.time.split(\":\");\n  const start = new Date(`${data.date}T${data.time}:00`);\n\n  start.setMinutes(start.getMinutes() + data.duration_minutes);\n\n  const yyyy = start.getFullYear();\n  const mm = String(start.getMonth() + 1).padStart(2, \"0\");\n  const dd = String(start.getDate()).padStart(2, \"0\");\n  const hh = String(start.getHours()).padStart(2, \"0\");\n  const min = String(start.getMinutes()).padStart(2, \"0\");\n\n  return `${yyyy}-${mm}-${dd}T${hh}:${min}:00`;\n})()\n}}",
        "useDefaultReminders": "={{ false }}",
        "additionalFields": {
          "attendees": [
            "={{ \nJSON.parse($node[\"Message a model\"].json.output[0].content[0].text)\n  .attendees_emails?.[0] \n}}"
          ],
          "summary": "={{\nJSON.parse($node[\"Message a model\"].json.output[0].content[0].text).title\n}}"
